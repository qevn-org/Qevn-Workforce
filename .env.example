# ==============================================================================
# QEVN Workforce Platform - Environment Variables Template
# ==============================================================================

# --- DATABASE & CACHE ---
# Supabase or other managed PostgreSQL connection string
DATABASE_URL=postgresql://postgres:[password]@db.supabase.co:5432/postgres
# Upstash or Redis Labs connection string
REDIS_URL=redis://default:[password]@your-redis-url.upstash.io:6379/0

# --- SERVICE ROUTINGS ---
# Port Gateway runs on (Default: 8000)
PORT=8000
# Deployed URL of the Orchestrator service (Gateway forwards requests here)
ORCHESTRATOR_URL=https://your-orchestrator-service-url.run.app

# --- LLM PROVIDER CREDENTIALS ---
# Provide at least one key to enable real supervisor agent planning:
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_MODEL=gpt-4o
# OR:
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# ANTHROPIC_MODEL=claude-3-5-sonnet-20240620

# --- SAAS INTEGRATIONS ---
# Twilio credentials for VoIP escalations
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_FROM_NUMBER=+1234567890

# HubSpot Access Token for CRM sync
HUBSPOT_ACCESS_TOKEN=pat-na1-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Slack Bot User OAuth Token for messaging
SLACK_BOT_TOKEN=xoxb-xxxxxxxxxxxx-xxxxxxxxxxxxx-xxxxxxxxxxxxxxxx

# Google API Credentials (Gmail / Calendar tools)
# (In production, these are refreshed dynamically using OAuth client credentials)
GMAIL_CLIENT_ID=xxxxxxxxxxxx-xxxxxxxxxxxxxxxx.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxxxxxxx

# --- SECURITY & AUTHENTICATION ---
# A 32-byte url-safe base64-encoded key used to encrypt credentials in PostgreSQL.
# You can generate this using: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
QEVN_ENCRYPTION_KEY=your-32-byte-fernet-key-here

# Clerk JWT validation keys (for Gateway REST authentication validation)
CLERK_JWKS_URL=https://api.clerk.com/v1/jwks
CLERK_AUDIENCE=qevn-workforce
